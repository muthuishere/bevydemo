# MathQuest Runtime Configuration
# Copy this file to .env and adjust values for your environment

# Language code for the default UI language (en, es, fr, zh, ta)
DEFAULT_LANGUAGE=en

# Enable or disable text-to-speech narration
TTS_ENABLED=true

# TTS backend to use: web | native | audio_fallback
TTS_BACKEND=web

# Enable anonymised analytics reporting
ANALYTICS_ENABLED=false

# Enable developer cheat shortcuts (skip levels, instant win, etc.)
DEBUG_CHEATS=false

# Override the asset search path (leave blank to use the default ./assets)
ASSET_PATH_OVERRIDE=

# Logging verbosity: error | warn | info | debug | trace
LOG_LEVEL=info

# Skip the intro/splash screen on startup
SKIP_INTRO=false

# Master volume multiplier (0.0 = silent, 1.0 = full)
MASTER_VOLUME=1.0

# Sound-effects volume multiplier
SFX_VOLUME=1.0

# Background music volume multiplier
MUSIC_VOLUME=0.7
